{
  "buildCommand": "pip install -r requirements.txt",
  "outputDirectory": "public",
  "framework": "python",
  "python": {
    "version": "3.11"
  },
  "functions": {
    "api/app.py": {
      "memory": 3008,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/app"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.11"
  }
}
